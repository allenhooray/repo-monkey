{
  "name": "repo-monkey-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "Workspace for the Repo Monkey extension and website",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter @repo-monkey/extension dev",
    "build": "pnpm --filter @repo-monkey/extension build",
    "build:zip": "pnpm --filter @repo-monkey/extension build:zip",
    "type-check": "pnpm --filter @repo-monkey/extension type-check"
  }
}
